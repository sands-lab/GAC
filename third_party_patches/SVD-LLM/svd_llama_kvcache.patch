+def apply_rotary_pos_emb(q, k, cos, sin, position_ids, key_position_ids=None):
+    q_cos, q_sin = _gather_rotary_cache(cos, sin, position_ids)
+    if key_position_ids is None:
+        key_position_ids = position_ids
+    k_cos, k_sin = _gather_rotary_cache(cos, sin, key_position_ids)
+
+    q_embed = (q * q_cos) + (rotate_half(q) * q_sin)
+    k_embed = (k * k_cos) + (rotate_half(k) * k_sin)
     return q_embed, k_embed
 
 
+def build_full_position_ids(position_ids, past_key_values_length):
+    if past_key_values_length == 0:
+        return position_ids
+
+    full_position_ids = []
+    for batch_position_ids in position_ids:
+        if batch_position_ids.numel() > 1:
+            position_deltas = batch_position_ids[1:] - batch_position_ids[:-1]
+            if not torch.all(position_deltas == 1):
+                raise ValueError(
+                    "SVD_LlamaAttention KV-cache path expects contiguous position_ids per batch."
+                )
+
+        start = int(batch_position_ids[0].item()) - past_key_values_length
+        if start < 0:
+            raise ValueError(
+                "SVD_LlamaAttention KV-cache path requires non-negative reconstructed position_ids."
+            )
+
+        stop = int(batch_position_ids[-1].item()) + 1
+        full_position_ids.append(
+            torch.arange(
+                start,
+                stop,
+                device=position_ids.device,
+                dtype=position_ids.dtype,
+            )
+        )
+
+    return torch.stack(full_position_ids, dim=0)
+
