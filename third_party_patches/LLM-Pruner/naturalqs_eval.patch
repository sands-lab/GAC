+    @classmethod
+    def _compute_f1(cls, prediction, ground_truth):
+        gold_tokens = cls._normalize_answer(ground_truth).split()
+        pred_tokens = cls._normalize_answer(prediction).split()
+        common = set(gold_tokens) & set(pred_tokens)
+        num_same = sum(
+            min(gold_tokens.count(token), pred_tokens.count(token)) for token in common
+        )
+
+        if not gold_tokens and not pred_tokens:
+            return 1.0
+        if not gold_tokens or not pred_tokens or num_same == 0:
+            return 0.0
+
+        precision = num_same / len(pred_tokens)
+        recall = num_same / len(gold_tokens)
+        return 2 * precision * recall / (precision + recall)
